programa
{
    funcao inicio()
    {
        inteiro senha

        escreva("Informe a senha: ")
        leia(senha)

        se (senha == 1234)
        {
            escreva("Acesso liberado")
        }
        senao
        {
            escreva("Senha incorreta")
        }
    }
} //Faltou solicitar para informar a senha e alterar o != para um == siguinificado