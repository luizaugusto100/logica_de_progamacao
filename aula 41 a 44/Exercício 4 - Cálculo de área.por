programa
{
    funcao inicio()
    {
        real largura, altura, area
         
        escreva("Informe a largura: ")
        leia(largura)

        escreva("Informe a altura: ")
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
} //Faltou solicitar para informar a altura e largura, além de adicionar altura e largura no formato real.