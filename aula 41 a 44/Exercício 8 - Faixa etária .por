programa
{
    funcao inicio()
    {
        inteiro idade

        escreva("Informe sua idade: ")
        leia(idade)

        se (idade >= 12 ou idade <= 17)
        {
            escreva("Adolescente")
        }
        senao
        {
            escreva("Não é adolescente")
        }
    }
} //Faltou adicionar o escreva para solicitar a idade.