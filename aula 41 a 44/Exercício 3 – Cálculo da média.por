programa
{
    funcao inicio()
    {
        real nota1, nota2, media

        escreva("Digite o primeiro número: ")
        leia(nota1)

        escreva("Digite o segundo número: ")
        leia(nota2)

        media = (nota1 + nota2) / 2

        escreva("Média: ", media)
    }
}//Faltou completar o n1 para nota1 e o n2 para nota2
 //Faltou adicionar dois escrevas um para a primeira nota e um para a segunda.
//Faltou alterar a divisão de 3 para 2.