programa {
  funcao inicio() {
    real a
    real b
    real trocaDeValorA
    real trocaDeValorB


    escreva("Digite o valor da letra A: ")
    leia( a)

    escreva("Digite o valor da letra B: ")
    leia( b)

    trocaDeValorA = b
    trocaDeValorB = a
    
    escreva(" A ganhou o valor de B: ", trocaDeValorA, "\n")
  

    escreva(" B ganhou o valor de A: ", trocaDeValorB)
    



  }
}
