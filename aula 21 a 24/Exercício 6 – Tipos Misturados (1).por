programa {
  funcao inicio() {
    
    
    cadeia produto
    inteiro codigo
    real preco
    logico disponivel

    

    
    produto = "Arroz"
    codigo = 1800
    preco = 21.99
    disponivel = verdadeiro


    escreva("produto: ", produto, "\n")
    escreva("código: ", codigo, "\n")
    escreva("Preço: R$", preco, "\n")
    escreva("Está disponivel: ", disponivel, "\n")
  }
}
