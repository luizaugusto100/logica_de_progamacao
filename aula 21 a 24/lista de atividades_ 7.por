programa {
  funcao inicio() {
    real temperaturaCelcius
    real temperaturaFahrenheit


    escreva(" Digite a temperatura em graus Celsius: ")
    leia(temperaturaCelcius)

    temperaturaFahrenheit = (9 * temperaturaCelcius + 160) / 5

    escreva("O valor da temperatura em Fahrenheit é de: ", temperaturaFahrenheit)
    


  }
}
