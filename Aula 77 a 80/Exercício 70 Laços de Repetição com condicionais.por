programa {
  funcao inicio() {

    inteiro numero

    escreva("Informe o número: ")
    leia(numero)

    enquanto(numero == numero){
    se(numero > 0){
      escreva("Número positivo.", "\n")
    }
    senao se(numero == 0){
      escreva("Zero.")
    } 
    senao se(numero < 0){
      escreva("Número negativo.")
    }
   }
  }
}
